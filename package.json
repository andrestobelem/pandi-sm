{
  "name": "pandi-sm",
  "version": "0.0.0",
  "description": "A Smalltalk implementation in Node.js — tree-walking runtime (lexer, parser, object model, evaluator), no image.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.17.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=default --reporter=junit",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "st-run": "node -e \"console.error('pandi-sm st-run: no implementado todavia (la CLI llega con L4). Exit 2.'); process.exit(2)\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
